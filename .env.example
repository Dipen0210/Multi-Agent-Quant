# ── Stack selection ────────────────────────────────────────────────
# Set to "free" (Groq + HuggingFace) or "bedrock" (AWS Bedrock + SageMaker)
STACK=free

# ── Groq (free tier LLM) ───────────────────────────────────────────
GROQ_API_KEY=

# ── AWS (Bedrock + SageMaker upgrade, also used for S3/Lambda) ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
SAGEMAKER_ENDPOINT=        # upgrade only: your FinBERT endpoint name

# ── HuggingFace (free tier FinBERT hosting) ────────────────────────
HF_SPACES_URL=             # e.g. https://your-username-finbert.hf.space
HF_API_TOKEN=

# ── Pinecone ───────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=quantsentiment

# ── Tavily ─────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Alpaca Paper Trading ───────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── LangSmith (observability) ──────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=quantsentiment-agent

# ── Agent settings ─────────────────────────────────────────────────
CRITIC_CONFIDENCE_THRESHOLD=0.65
RISK_MAX_SINGLE_STOCK_PCT=0.10
RISK_STOP_LOSS_PCT=0.05
